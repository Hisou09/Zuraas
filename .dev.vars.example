# Google OAuth 2.0 (Google Cloud Console -> OAuth client -> Web application)
# GOOGLE_REDIRECT_URI-г хоосон үлдээвэл тухайн ажиллаж буй сайтын
# /api/auth/google/callback хаягийг автоматаар ашиглана.
# Дурын Google хэрэглэгч нэвтрэхийн тулд Google Auth Platform дээр
# Audience-ийг External болгож, app-аа Production төлөвт publish хийнэ.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
